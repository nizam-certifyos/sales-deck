  "identifier_formats": {
    "npi": {
      "regex": "^\\d{10}$",
      "exact_length": 10,
      "digits_only": true,
      "description": "National Provider Identifier"
    },
    "tin": {
      "regex": "^\\d{9}$",
      "exact_length": 9,
      "digits_only": true,
      "description": "Tax Identification Number"
    },
    "ssn": {
      "regex": "^\\d{9}$",
      "exact_length": 9,
      "digits_only": true,
      "description": "Social Security Number"
    },
    "caqh": {
      "regex": "^\\d{7,8}$",
      "min_length": 7,
      "max_length": 8,
      "digits_only": true,
      "description": "CAQH ID"
    },
    "medicare_id": {
      "regex": "^[a-zA-Z0-9]{5,20}$",
      "min_length": 5,
      "max_length": 20,
      "description": "Medicare ID"
    },
    "medicaid_id": {
      "regex": "^[a-zA-Z0-9]{5,20}$",
      "min_length": 5,
      "max_length": 20,
      "description": "Medicaid ID"
    },
    "phone": {
      "regex": "^\\d{10}$",
      "exact_length": 10,
      "digits_only": true,
      "description": "Phone/Fax Number"
    },
    "zip_5": {
      "regex": "^\\d{5}$",
      "exact_length": 5,
      "digits_only": true,
      "description": "ZIP Code (5 digit)"
    },
    "zip_9": {
      "regex": "^\\d{9}$",
      "exact_length": 9,
      "digits_only": true,
      "description": "ZIP Code (9 digit)"
    },
    "zip_full": {
      "regex": "^(\\d{5}(-\\d{4})?|\\d{9})$",
      "description": "ZIP Code (any valid format)"
    },
    "state": {
      "regex": "^[A-Z]{2}$",
      "exact_length": 2,
      "description": "State 2-letter code"
    },
    "email": {
      "regex": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$",
      "description": "Email address"
    },
    "date": {
      "regex": "^\\d{4}-\\d{2}-\\d{2}$",
      "format": "YYYY-MM-DD",
      "description": "ISO date"
    }
  },
  "date_year_range": {
    "min": 1901,
    "max": 2099
  },
  "scientific_notation_regex": "^[+-]?\\d+(?:\\.\\d+)?[eE][+-]?\\d+$",
  "pure_numeric_threshold": 0.98,
  "sparse_row_threshold": 0.8,
  "nppes": {
    "bq_table_production": "{NPPES_BQ_TABLE}",
    "api_url": "https://npiregistry.cms.hhs.gov/api/?number={npi}&version=2.1",
    "api_delay_ms": 500,
    "entity_types": {
      "NPI-1": "Individual",
      "NPI-2": "Organization"
    },
    "name_matching": "REGEXP_REPLACE(UPPER(name), r'[^A-Z]', '')",
    "npi_columns_practitioner": [
      "NPI",
      "Group Billing NPI",
      "Supervising Provider NPI",
      "Supplier NPI"
    ],
    "npi_columns_facility": [
      "NPI",
      "Group NPI",
      "Group Billing NPI"
    ]
  },
  "bq_column_name_rules": {
    "max_length": 300,
    "allowed_chars": "A-Za-z0-9_",
    "must_start_with": "letter or underscore",
    "sanitize_regex": "[^A-Za-z0-9_] \u2192 _",
    "collapse_underscores": true,
    "strip_leading_trailing_underscores": true
  },
  "name_validation_regex": "^[A-Za-z\\s\\-\\']+$"
}